# --- Bootstrap / infra config (read at startup; everything else is in the admin GUI: /admin/settings) ---

# Modem / serial
SERIAL_SEND_PORT=/dev/ttyUSB2
SERIAL_READ_PORT=/dev/ttyUSB3
SERIAL_BAUDRATE=115200

# Storage
DB_PATH=data/sms.db

# Server
HOST=0.0.0.0
PORT=80

# Admin UI (HTTP Basic). CHANGE THESE before exposing the service.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# NOTE: voxlink, Telegram alerting, inbound dispatch, blacklist threshold,
# delivery timeout, and phone_region (validation country, seeded to RU) are now
# configured at runtime via /admin/settings (stored in the DB). Client app tokens
# are managed via /admin/apps. On first start, any of these still present in this
# file are migrated into the DB once, then ignored here.
